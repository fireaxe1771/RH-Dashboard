# =========================================================================
# RECOVERYHUB DASHBOARD SYSTEM ENVIRONMENT CONFIGURATION
# This is a development configuration for local Docker Compose setup
# =========================================================================

# --- Web Server settings ---
PORT=8000

# --- Metadata DB (MongoDB) configuration ---
# For local docker-compose, this is auto-routed to the local Mongo container
# The docker-compose.yml overrides this with mongodb://mongo:27017
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=recoveryhub_dashboard_dev

# --- Target SQL Database (Azure SQL) configuration ---
# The primary database where emergency fire runs, claims, and invoices live.
# Replace with your actual Azure SQL credentials
AZURE_SQL_HOST=your-azure-sql-server.database.windows.net
AZURE_SQL_PORT=1433
AZURE_SQL_DB=RecoveryHubClaims
AZURE_SQL_USER=dashboard_reader_user
AZURE_SQL_PASSWORD=your_secure_azure_sql_password

# --- Entra ID Authentication configuration ---
# Microsoft OAuth 2.0 Credentials (tenant-specific streamlineas.com setup)
# Replace with your actual Azure AD application credentials
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
VITE_AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
VITE_AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000